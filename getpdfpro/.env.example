# ─── App ──────────────────────────────────────────────────
ENV=development
VERSION=0.1.0
DEBUG=true
LOG_LEVEL=DEBUG

# ─── CORS (comma-separated) ─────────────────────────────────
CORS_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:8080

# ─── Supabase ─────────────────────────────────────────────
# Get from https://app.supabase.com/project/_/settings/api
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.YOUR_ANON_KEY
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.YOUR_SERVICE_ROLE_KEY

# ─── Database ─────────────────────────────────────────────
# Local: postgresql+asyncpg://postgres:postgres@localhost:5432/getpdfpro
# Production: use Supabase connection string
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/getpdfpro

# ─── Redis ────────────────────────────────────────────────
# Local: redis://localhost:6379/0
# Production: Upstash: rediss://default:***@***.upstash.io:6379
REDIS_URL=redis://localhost:6379/0

# ─── Cloudflare R2 (S3-compatible) ────────────────────────
# Get from https://dash.cloudflare.com/?to=/:account/r2/api-tokens
R2_ENDPOINT_URL=https://YOUR_ACCOUNT_ID.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=your_r2_access_key
R2_SECRET_ACCESS_KEY=your_r2_secret_key
R2_BUCKET=getpdfpro-prod
R2_REGION=auto
R2_PUBLIC_URL=https://files.getpdfpro.com

# ─── Google Gemini ────────────────────────────────────────
# Get from https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key
GEMINI_DEFAULT_MODEL=gemini-1.5-flash-8b
GEMINI_PRO_MODEL=gemini-1.5-pro

# ─── Resend (email) ───────────────────────────────────────
# Get from https://resend.com/api-keys
RESEND_API_KEY=re_your_api_key
RESEND_FROM_EMAIL=GetPDFPro <noreply@getpdfpro.com>

# ─── Stripe ───────────────────────────────────────────────
# Get from https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_your_key
STRIPE_WEBHOOK_SECRET=whsec_your_secret

# ─── Razorpay ─────────────────────────────────────────────
# Get from https://dashboard.razorpay.com/app/keys
RAZORPAY_KEY_ID=rzp_test_your_key
RAZORPAY_KEY_SECRET=your_secret
RAZORPAY_WEBHOOK_SECRET=your_webhook_secret

# ─── HaveIBeenPwned ───────────────────────────────────────
HIBP_USER_AGENT=GetPDFPro-SecurityCheck

# ─── Celery ───────────────────────────────────────────────
CELERY_CONCURRENCY=2

# ─── Optional: Sentry (error tracking) ───────────────────
# SENTRY_DSN=https://***@***.ingest.sentry.io/***
