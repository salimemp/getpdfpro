# Security headers — ported from apps/web/next.config.js.
#
# Cloudflare Pages reads this file at deploy time and applies the
# headers to all matching responses. Format:
#   <path-pattern>
#     <Header-Name>: <value>
#
# Two scope levels: site-wide (/*) and per-asset (/icons, /blog).
# The site-wide block is the moral equivalent of next.config.js's
# `headers()` function with source: "/(.*)".

/*
  X-Content-Type-Options: nosniff
  X-Frame-Options: DENY
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: camera=(self), microphone=(self), geolocation=()
  Strict-Transport-Security: max-age=63072000; includeSubDomains; preload
