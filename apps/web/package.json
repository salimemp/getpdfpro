{
  "name": "web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --port 3000",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "rm -rf .next .turbo node_modules .open-next",
    "pages:build": "opennextjs-cloudflare build && cp _headers .open-next/_headers",
    "pages:dev": "opennextjs-cloudflare build && cp _headers .open-next/_headers && wrangler pages dev .open-next",
    "pages:deploy": "opennextjs-cloudflare build && cp _headers .open-next/_headers && wrangler pages deploy .open-next"
  },
  "dependencies": {
    "@supabase/ssr": "0.5.1",
    "@supabase/supabase-js": "2.45.4",
    "clsx": "2.1.1",
    "lucide-react": "0.453.0",
    "next": "15.5.19",
    "next-intl": "^3.26.5",
    "react": "19.0.0",
    "react-dom": "19.0.0"
  },
  "devDependencies": {
    "@opennextjs/cloudflare": "^1.5.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "22.9.0",
    "@types/react": "19.0.0",
    "@types/react-dom": "19.0.0",
    "@vitejs/plugin-react": "^6.0.2",
    "@vitest/coverage-v8": "^4.1.8",
    "autoprefixer": "10.4.20",
    "eslint": "9.14.0",
    "eslint-config-next": "15.5.19",
    "jsdom": "^29.1.1",
    "postcss": "8.5.10",
    "tailwindcss": "3.4.14",
    "typescript": "5.6.3",
    "vitest": "^4.1.8",
    "wrangler": "^3.99.0"
  }
}
