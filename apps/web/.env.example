# =============================================================================
# GetPDFPro Web App — environment variables
# Copy to .env.local for local dev. Never commit .env.local.
# =============================================================================

# Supabase (https://supabase.com/dashboard)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOi...

# Backend API — what the browser hits for PDF processing
NEXT_PUBLIC_API_URL=http://localhost:8000

# Public site URL — read by app/layout.tsx (metadataBase, og:url) and
# lib/site.ts (SITE_URL) for canonical/OG/sitemap/robots. Defaults to
# https://app.getpdfpro.com when unset, but you should set this
# explicitly per environment so Vercel previews and Cloudflare Pages
# deploys get correct absolute URLs in <link rel="canonical"> etc.
# Production value: https://app.getpdfpro.com
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Stripe (https://dashboard.stripe.com/apikeys)
# Set NEXT_PUBLIC_STRIPE_ENABLED=1 once you've added your publishable key
# AND the API service has the corresponding secret key + price IDs.
# Until then, the /pricing page shows the beta fallback and checkout
# calls return 503.
NEXT_PUBLIC_STRIPE_ENABLED=

# --- Dead vars (intentionally commented out, do not uncomment) ---
# The 4 vars below are NOT referenced in apps/web source. They are kept
# here as commented placeholders so a future engineer can see what was
# considered and rejected. Verified via:
#   git grep -n 'NEXT_PUBLIC_<NAME>' apps/web/ ':!*.lock' ':!*.example*'
# - NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY: pricing/ checkout uses
#   NEXT_PUBLIC_STRIPE_ENABLED only; the API side holds the secret key.
# - NEXT_PUBLIC_RAZORPAY_KEY_ID: Razorpay integration lives in apps/api,
#   not apps/web. Wire it up first before uncommenting.
# - NEXT_PUBLIC_POSTHOG_KEY / _HOST: analytics is not enabled; remove
#   these comments when PostHog is added.
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
# NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_test_...
# NEXT_PUBLIC_POSTHOG_KEY=
# NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
