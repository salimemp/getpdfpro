# =============================================================================
# GetPDFPro Web App — environment variables
# Copy to .env.local for local dev. Never commit .env.local.
# =============================================================================

# Supabase (https://supabase.com/dashboard)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOi...

# Backend API — what the browser hits for PDF processing
NEXT_PUBLIC_API_URL=http://localhost:8000

# Stripe (https://dashboard.stripe.com/apikeys)
# Set NEXT_PUBLIC_STRIPE_ENABLED=1 once you've added your publishable key
# AND the API service has the corresponding secret key + price IDs.
# Until then, the /pricing page shows the beta fallback and checkout
# calls return 503.
NEXT_PUBLIC_STRIPE_ENABLED=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# Razorpay (https://dashboard.razorpay.com/app/keys) — India
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_test_...

# PostHog analytics (optional)
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
