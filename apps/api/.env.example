# =============================================================================
# GetPDFPro API — environment variables
# Copy to .env for local dev. Never commit .env.
# =============================================================================

ENV=development
PORT=8000
LOG_LEVEL=info

# CORS — comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:3000,https://getpdfpro.com,https://app.getpdfpro.com

# Supabase (https://supabase.com/dashboard)
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOi...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...

# Redis (local: redis://localhost:6379 | Railway: redis://default:xxx@redis.railway.internal:6379)
REDIS_URL=redis://localhost:6379

# ─── Rate limits / cost guardrails (optional, all have sane defaults) ───
FREE_TIER_DAILY_TASKS=50
FREE_TIER_MAX_FILE_SIZE_MB=100
PRO_TIER_MAX_FILE_SIZE_MB=4096

# ─── App metadata ───
APP_VERSION=0.1.0
LOG_LEVEL=info

# Google Gemini (https://aistudio.google.com/app/apikey)
GEMINI_API_KEY=AIzaSy...
GEMINI_MODEL=gemini-1.5-flash-8b
GEMINI_PRO_MODEL=gemini-1.5-pro

# Cloudflare R2 (https://dash.cloudflare.com/?to=/:account/r2)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=getpdfpro-uploads
R2_PUBLIC_URL=https://pub-YOUR_BUCKET.r2.dev

# Stripe (https://dashboard.stripe.com/apikeys)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Razorpay (https://dashboard.razorpay.com/app/keys)
RAZORPAY_KEY_ID=rzp_test_...
RAZORPAY_KEY_SECRET=

# Sentry (optional)
SENTRY_DSN=

# ─── PDF → Office conversion adapters ───
# Tier 1: Adobe PDF Services (free tier, 500 Document Transactions/month)
# Get credentials at https://developer.adobe.com/document-services/apis/pdf-services/
# 1. Sign in / create an Adobe Developer account
# 2. Create a new project (PDF Services API)
# 3. Add the "PDF Services API" credential
# 4. Copy the Client ID and Client Secret below
ADOBE_CLIENT_ID=
ADOBE_CLIENT_SECRET=

# Tier 2: LibreOffice (self-hosted). No env var needed — the
# `libreoffice-core` + `libreoffice-writer` + `libreoffice-calc` +
# `libreoffice-impress` packages are installed in the Dockerfile.
# Quality: 90-95% layout fidelity. No per-conversion cost. Supports
# docx, xlsx, pptx. Configurable via the env vars below.
# Max concurrent soffice processes (each uses ~150MB RAM):
LIBREOFFICE_MAX_CONCURRENCY=2
# Per-conversion timeout in seconds:
LIBREOFFICE_TIMEOUT_S=60
